# Vercel / app
APP_URL="https://your-project.vercel.app"
VITE_API_URL=""

# Auth
JWT_SECRET="replace_with_a_long_random_secret"

# Cloud MySQL. Prefer DATABASE_URL when your provider gives one.
# Example: mysql://USER:PASSWORD@HOST:3306/DB_NAME
DATABASE_URL=""

# Alternative to DATABASE_URL:
DB_HOST=""
DB_PORT="3306"
DB_USER=""
DB_PASSWORD=""
DB_NAME="rise_foundation"

# Enable this for cloud MySQL providers that require TLS/SSL.
DB_SSL="true"
DB_SSL_REJECT_UNAUTHORIZED="true"
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Optional
DB_CONNECTION_LIMIT="2"
DEBUG_API_ERRORS="true"
GEMINI_API_KEY="MY_GEMINI_API_KEY"
